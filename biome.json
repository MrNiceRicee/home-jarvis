{
	"$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"css": {
		"parser": {
			"allowWrongLineComments": false,
			"cssModules": false,
			"tailwindDirectives": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "all",
			"semicolons": "asNeeded"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [":BUN:", ":NODE:", ":PACKAGE:", ":BLANK_LINE:", ":PATH:"],
						"identifierOrder": "natural"
					}
				}
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": false,
			"performance": {
				"noAccumulatingSpread": "error"
			},
			"correctness": {
				"noConstantMathMinMaxClamp": "error",
				"noNodejsModules": "error"
			}
		}
	},
	"overrides": [
		{
			"includes": ["server/**", "scripts/**"],
			"linter": {
				"rules": {
					"correctness": {
						"noNodejsModules": "off"
					}
				}
			}
		}
	],
	"files": {
		"includes": [
			"**",
			"!**/.claude/**",
			"!**/dist/**",
			"!**/.turbo/**",
			"!**/node_modules/**",
			"!**/routeTree.gen.ts"
		]
	}
}
