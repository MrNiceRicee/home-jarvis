{
	"name": "home-jarvis",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.10",
	"workspaces": [
		"server",
		"client"
	],
	"scripts": {
		"dev": "turbo dev db:studio",
		"dev:app": "turbo dev --filter=home-jarvis-server --filter=client",
		"build": "turbo build",
		"lint": "turbo lint",
		"lint:fix": "turbo lint:fix",
		"typecheck": "turbo typecheck",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"db:push": "turbo db:push",
		"db:studio": "turbo db:studio",
		"system:check": "turbo lint typecheck",
		"gen:client": "bun run scripts/gen-client-manifest.ts",
		"build:prod": "turbo build --filter=client && bun run gen:client && bun build --compile --minify server/src/index.ts --outfile dist/jarvis"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@eslint/js": "^10.0.1",
		"eslint": "^10.0.2",
		"eslint-plugin-boundaries": "^5.4.0",
		"eslint-plugin-sonarjs": "^4.0.0",
		"globals": "^17.3.0",
		"jiti": "^2.6.1",
		"turbo": "latest",
		"typescript-eslint": "^8.56.1"
	},
	"dependencies": {
		"@elysiajs/eden": "^1.4.8"
	}
}
