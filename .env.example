# ports — override if 3001/5173 conflict with other local apps
PORT=3001
CLIENT_PORT=5173

# urls — must match ports above (used for OAuth callbacks and CORS)
SERVER_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# database — defaults to server/data/jarvis.db in dev, ./data/jarvis.db in prod
# DB_PATH=/absolute/path/to/jarvis.db

# oauth — random per-restart if unset (invalidates in-flight OAuth flows)
# OAUTH_STATE_SECRET=

# resideo (honeywell) — required for Resideo OAuth integration
# RESIDEO_CONSUMER_KEY=
# RESIDEO_CONSUMER_SECRET=

# smarthq (ge) — required for SmartHQ OAuth integration
# SMARTHQ_CLIENT_ID=
# SMARTHQ_CLIENT_SECRET=
